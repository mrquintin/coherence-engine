# ---------------------------------------------------------------------------
# Build outputs. Installers and staging are produced by
# scripts/build-installers.command and attached to GitHub Releases by
# scripts/sync-to-github.sh. They are NEVER committed to the repo — a single
# .pkg/.dmg can run into the hundreds of MB and trip GitHub's 100 MB per-file
# push limit. Release URLs from raw.githubusercontent.com/.../releases/latest/
# download/ serve them directly from Releases, so "offline install" via a
# git clone is not a supported path.
# ---------------------------------------------------------------------------
build/installers/
build/release-artifacts/
build/.installer-work/

# ---------------------------------------------------------------------------
# Language / ecosystem caches
# ---------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / JS
node_modules/
.cache/
.parcel-cache/
.next/
.turbo/

# Rust / Tauri
target/
**/*.rs.bk

# macOS / Xcode
.DS_Store
DerivedData/
*.xcworkspace/xcuserdata/
*.xcuserdatad/
xcuserdata/
*.hmap
*.moved-aside
build/Build/

# Flutter / Dart
.flutter-plugins
.flutter-plugins-dependencies
.dart_tool/
.packages
.pub-cache/
.pub/

# Editor cruft
.idea/
*.swp
*.swo
.vscode/*.log

# Credentials / local env (never commit)
.env
.env.*
!.env.example

# SQLite databases and their journal/WAL sidecars (runtime state, not source)
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# Runtime state directory (notifications dumps, transient app data)
var/
