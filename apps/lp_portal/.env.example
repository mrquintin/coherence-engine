# Supabase project — both values are public-by-design (anon key is RLS-gated).
# Copy to apps/lp_portal/.env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Coherence Fund backend (FastAPI). The LP portal calls a small surface
# under /api/v1/lp/<lp_id>/... that the backend gates with row-level
# security keyed off the Supabase access token + lp_id app-metadata claim.
NEXT_PUBLIC_LP_API_BASE_URL=http://localhost:8000

# Hosted bank-link entrypoint for LP funding-source setup. This should point
# to a backend endpoint or processor-hosted session starter that creates a
# Stripe Financial Connections / ACH setup flow, Plaid hosted Link flow, or
# equivalent regulated provider flow. The LP portal app never accepts raw
# account or routing numbers directly.
LP_BANK_LINK_START_URL=
NEXT_PUBLIC_LP_BANK_LINK_PROVIDER=Stripe Financial Connections

# DO NOT add SUPABASE_SERVICE_ROLE_KEY here. It must never be present in any
# Vercel environment for this project — it would let a compromised LP-portal
# build read or write any LP's data. Service-role operations belong on the
# backend, behind the treasurer / partner-dashboard surface.
