{
  "name": "@coherence/founder-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Coherence Fund founder-facing Next.js portal (Vercel-deployable, App Router).",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "generate:sdk": "python3 ../../scripts/generate_ts_sdk.py"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@supabase/ssr": "0.5.1",
    "@supabase/supabase-js": "2.45.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.0",
    "@playwright/test": "1.47.2",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "happy-dom": "15.7.4",
    "postcss": "8.4.47",
    "prettier": "3.7.4",
    "tailwindcss": "3.4.13",
    "typescript": "5.5.4",
    "vitest": "2.1.1"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  }
}
