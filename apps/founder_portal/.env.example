# Supabase project — both values are public-by-design (anon key is RLS-gated).
# Copy to apps/founder_portal/.env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Coherence Fund backend (FastAPI). Use the staging hostname for preview
# deployments and the prod hostname for the production Vercel project.
BACKEND_API_URL=http://localhost:8000

# DO NOT add SUPABASE_SERVICE_ROLE_KEY here. It must never be present in any
# Vercel environment for this project — it would expose admin write access
# from a static-edge runtime. Service-role operations belong on the backend.
