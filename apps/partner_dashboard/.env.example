# Supabase project — both values are public-by-design (anon key is RLS-gated).
# Copy to apps/partner_dashboard/.env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Coherence Fund backend (FastAPI). Partner dashboard hits /api/v1/partner/*.
BACKEND_API_URL=http://localhost:8000

# DO NOT add SUPABASE_SERVICE_ROLE_KEY here. The partner dashboard runs on
# Vercel's edge runtime and a service-role key would expose admin writes from
# a static-edge surface. Service-role operations belong on the backend only.
