---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — Coherence Engine"
  description="How to reach the Coherence Engine team — research correspondence, founder applications, and press."
>
  <section class="prose">
    <p class="text-sm uppercase tracking-wide text-muted not-prose">Contact</p>
    <h1 class="mt-2">Get in touch</h1>

    <h2>Founders</h2>
    <p>
      Apply through the founder portal. The portal is the only intake we underwrite from; cold
      email rarely surfaces above noise.
    </p>

    <h2>Research correspondence</h2>
    <p>
      Replications, critiques, and methodology questions are welcome. Please reference the paper
      slug (e.g. <code>cosine_paradox</code>) in your subject line and include your dataset or
      experimental setup if you are reporting a result.
    </p>
    <p>
      Email: <a href="mailto:research@coherence.example.com">research@coherence.example.com</a>
    </p>

    <h2>Press</h2>
    <p>
      Email: <a href="mailto:press@coherence.example.com">press@coherence.example.com</a>. We do
      not comment on portfolio companies or LPs.
    </p>

    <h2>What this page is not</h2>
    <p>
      This page does not collect form submissions to a backend. The site is fully static.
    </p>
  </section>
</BaseLayout>
