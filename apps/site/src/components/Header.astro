---
const links = [
  { href: '/', label: 'Thesis' },
  { href: '/research', label: 'Research' },
  { href: '/fund', label: 'Fund' },
  { href: '/results', label: 'Results' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="border-b border-ink/10 bg-paper">
  <nav aria-label="Primary" class="mx-auto max-w-3xl px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight no-underline text-ink">Coherence Engine</a>
    <ul class="flex gap-5 text-sm">
      {links.map((l) => {
        const active = path === l.href || (l.href !== '/' && path.startsWith(l.href));
        return (
          <li>
            <a
              href={l.href}
              class={`no-underline ${active ? 'text-accent font-medium' : 'text-ink/70 hover:text-ink'}`}
              aria-current={active ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
