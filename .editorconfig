# EditorConfig — https://editorconfig.org
# Shared whitespace conventions across editors and CI.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,yml,yaml,html,css,scss,md,mdx,astro}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
