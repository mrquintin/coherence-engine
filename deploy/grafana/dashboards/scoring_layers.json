      "description": "SLO_scoring_success — score-stage success ratio. Target ≥ 99% / 30d.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 1,
          "min": 0.95,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.985
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1001,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "1 - coherence_fund:slo_scoring:error_ratio:24h",
          "legendFormat": "SLO_scoring_success",
          "refId": "A"
        }
      ],
      "title": "SLO_scoring_success compliance (24h proxy for 30d)",
