# Upstash Redis env example for the fund Arq worker.
# Copy to /etc/default/coherence-fund (or your secret store) and fill in
# the values from your Upstash dashboard. Do NOT commit a populated copy.

# REQUIRED — Arq backend selection. Setting this to ``poll`` reverts to
# the legacy DB-polling worker without a code deploy.
WORKER_BACKEND=arq

# REQUIRED — Upstash TLS endpoint. The REST API endpoint is incompatible
# with Arq (which speaks RESP). Use ``rediss://`` (TLS) for production.
# Format: rediss://default:<token>@<endpoint>:6379
REDIS_URL=rediss://default:CHANGE_ME@us1-example-12345.upstash.io:6379

# OPTIONAL — queue-name prefix. Useful for multi-tenant Upstash plans
# where multiple environments share a single Redis db.
ARQ_QUEUE_PREFIX=coherence_fund
