# Copy to /etc/default/coherence-fund and customize.

# Core runtime
COHERENCE_FUND_DATABASE_URL=postgresql+psycopg://coherence:coherence@127.0.0.1:5432/coherence_fund
COHERENCE_FUND_AUTO_CREATE_TABLES=false
COHERENCE_FUND_SERVICE_NAME=fund-orchestrator-api
COHERENCE_FUND_SERVICE_VERSION=0.2.0

# Event schemas root (optional override)
COHERENCE_FUND_EVENT_SCHEMA_ROOT=

# Security
COHERENCE_FUND_AUTH_MODE=db
COHERENCE_FUND_RATE_LIMIT_ENABLED=true
COHERENCE_FUND_RATE_LIMIT_REQUESTS=120
COHERENCE_FUND_RATE_LIMIT_WINDOW_SECONDS=60
COHERENCE_FUND_BOOTSTRAP_ADMIN_ENABLED=true
COHERENCE_FUND_BOOTSTRAP_ADMIN_SECRET_REF=coherence/fund/bootstrap-admin
COHERENCE_FUND_BOOTSTRAP_ADMIN_CACHE_SECONDS=30
# Secret manager profile — align with your cloud (one primary per environment).
#   aws:   COHERENCE_FUND_SECRET_MANAGER_PROVIDER=aws + COHERENCE_FUND_AWS_REGION (below)
#   gcp:   COHERENCE_FUND_SECRET_MANAGER_PROVIDER=gcp + workload identity or
#          COHERENCE_FUND_GCP_ACCESS_TOKEN (short-lived; CI/automation only)
#   vault: COHERENCE_FUND_SECRET_MANAGER_PROVIDER=vault + COHERENCE_FUND_VAULT_ADDR + token fields below
COHERENCE_FUND_SECRET_MANAGER_PROVIDER=aws # aws|gcp|vault
COHERENCE_FUND_SECRET_MANAGER_TIMEOUT_SECONDS=5
COHERENCE_FUND_SECRET_MANAGER_TOKEN_FIELD=token
COHERENCE_FUND_SECRET_MANAGER_STRICT_POLICY=true
COHERENCE_FUND_SECRET_MANAGER_STARTUP_ENFORCE=true
COHERENCE_FUND_SECRET_MANAGER_ALLOW_STATIC_CREDENTIALS=false

# AWS Secrets Manager / Parameter Store (provider=aws)
COHERENCE_FUND_AWS_REGION=us-east-1

# GCP (provider=gcp) — prefer WIF on the host; token env is for automation only
# COHERENCE_FUND_GCP_ACCESS_TOKEN=

# Vault (only for provider=vault)
COHERENCE_FUND_VAULT_ADDR=
COHERENCE_FUND_VAULT_TOKEN=
COHERENCE_FUND_VAULT_TOKEN_FILE=
COHERENCE_FUND_VAULT_ALLOW_INSECURE_HTTP=false

# Dispatcher transport selector: kafka | sqs | redis
COHERENCE_FUND_OUTBOX_BACKEND=redis
COHERENCE_FUND_TOPIC_PREFIX=coherence.fund

# Kafka
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# SQS
AWS_REGION=us-east-1
SQS_QUEUE_URL=

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Health watchdog
COHERENCE_FUND_READY_URL=http://127.0.0.1:8010/ready
COHERENCE_FUND_SECRET_MANAGER_READY_URL=http://127.0.0.1:8010/api/v1/secret-manager/ready
COHERENCE_FUND_API_UNIT=coherence-fund-api.service
COHERENCE_FUND_WORKER_UNIT=coherence-fund-worker.service
COHERENCE_FUND_SCORING_WORKER_UNIT=coherence-fund-scoring-worker.service
COHERENCE_FUND_WATCHDOG_TIMEOUT_SECONDS=5

# Worker ops telemetry — in-process thresholds (0 = disabled, safe default)
COHERENCE_FUND_OUTBOX_OPS_QUEUE_WARN_DEPTH=0
COHERENCE_FUND_OUTBOX_OPS_OLDEST_WARN_SECONDS=0
COHERENCE_FUND_OUTBOX_OPS_FAILED_DLQ_WARN_COUNT=0
COHERENCE_FUND_SCORING_OPS_QUEUE_WARN_DEPTH=0
COHERENCE_FUND_SCORING_OPS_OLDEST_WARN_SECONDS=0
COHERENCE_FUND_SCORING_OPS_FAILED_DLQ_WARN_COUNT=0
# Example production starting points (uncomment and tune; see docs/ops/slo_threshold_standards.md):
# COHERENCE_FUND_OUTBOX_OPS_QUEUE_WARN_DEPTH=5000
# COHERENCE_FUND_OUTBOX_OPS_OLDEST_WARN_SECONDS=3600
# COHERENCE_FUND_OUTBOX_OPS_FAILED_DLQ_WARN_COUNT=10
# COHERENCE_FUND_SCORING_OPS_QUEUE_WARN_DEPTH=100
# COHERENCE_FUND_SCORING_OPS_OLDEST_WARN_SECONDS=1800
# COHERENCE_FUND_SCORING_OPS_FAILED_DLQ_WARN_COUNT=5

# Centralized ops sinks (optional; logs always include COHERENCE_FUND_WORKER_OPS_SNAPSHOT)
# JSONL append — no network
# COHERENCE_FUND_OPS_TELEMETRY_FILE_PATH=/var/log/coherence-fund/worker_ops.jsonl
# Prometheus textfile for node_exporter — use distinct paths per worker on same host
# COHERENCE_FUND_OPS_TELEMETRY_PROMETHEUS_TEXTFILE_PATH=/var/lib/node_exporter/textfile/coherence_scoring.prom
# (outbox unit) COHERENCE_FUND_OPS_TELEMETRY_PROMETHEUS_TEXTFILE_PATH=/var/lib/node_exporter/textfile/coherence_outbox.prom

# Optional in-process alert routing from worker warn snapshots (default mode=none)
# Modes: none | file | webhook
# COHERENCE_FUND_OPS_ALERT_ROUTER_MODE=none
# File mode:
# COHERENCE_FUND_OPS_ALERT_FILE_PATH=/var/log/coherence-fund/worker_ops_alerts.jsonl
# Webhook mode (Alertmanager/on-call bridge):
# COHERENCE_FUND_OPS_ALERT_WEBHOOK_URL=https://alerts.example.com/hooks/coherence-fund
# COHERENCE_FUND_OPS_ALERT_WEBHOOK_TOKEN=
# COHERENCE_FUND_OPS_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# Dedupe/cooldown controls:
# COHERENCE_FUND_OPS_ALERT_COOLDOWN_SECONDS=300
# COHERENCE_FUND_OPS_ALERT_DEDUPE_KEY=component_tags
# Optional per-tag severity overrides JSON:
# COHERENCE_FUND_OPS_ALERT_SEVERITY_MAP={"queue_depth":"warning","failed_dlq":"critical"}
#
# Put webhook URL/token in a root-only file or secret store — not world-readable env files in production.
#
# CI / cadence: recurring safe drills + optional live webhook POST are documented in
# docs/ops/runbooks/production_observability_rollout.md (.github/workflows/oncall-route-verification.yml).
#
# On-call rollout registry (no secrets in repo): copy deploy/ops/oncall-route-policy.example.json to a
# private policy file and keep environment rows aligned with PagerDuty escalation policies, Opsgenie teams,
# or Alertmanager receiver names. Verify locally:
#   python deploy/scripts/verify_oncall_route_policy.py --policy /path/to/oncall-route-policy.json
# Compare a host's effective env to one policy row (still no network):
#   COHERENCE_FUND_SECRET_MANAGER_PROVIDER=aws COHERENCE_FUND_OPS_ALERT_ROUTER_MODE=none \
#     python deploy/scripts/verify_oncall_route_policy.py --policy ... --env prod --check-env

