# Coherence Engine fund backend — environment variables.
#
# Copy to `.env` and fill in real values. Never commit secrets.
# Resolution order for the database URL is documented in
# `server/fund/database.py::resolve_database_url`.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Explicit override — when set, supersedes every Supabase fallback below.
# Useful for pointing dev at a managed Postgres outside of Supabase.
DATABASE_URL=

# Supabase pgbouncer (transaction-pool) URL — used by long-lived API workers
# (FastAPI under uvicorn). SQLAlchemy disables its own pool when this is set
# so it does not fight pgbouncer. Host typically ends with `.pooler.supabase.com`.
SUPABASE_DB_POOLER_URL=

# Supabase direct connection URL — used by Alembic migrations and one-shot
# admin jobs that need session-mode features (e.g. advisory locks). Host
# typically ends with `.supabase.co`.
SUPABASE_DB_URL=

# Supabase service-role JWT. Server-side only — NEVER expose to clients.
# Required for any code path that should bypass row-level security.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy SQLite fallback — leave as default unless you know you need it.
COHERENCE_FUND_DATABASE_URL=sqlite:///./coherence_fund.db

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------

COHERENCE_FUND_SERVICE_NAME=fund-orchestrator-api
COHERENCE_FUND_SERVICE_VERSION=0.2.0
COHERENCE_FUND_AUTH_MODE=db

# ---------------------------------------------------------------------------
# Supabase Auth (founder-portal JWT verification)
# ---------------------------------------------------------------------------
#
# JWKS document used to verify Supabase-issued asymmetric JWTs. Supabase
# publishes this at `${SUPABASE_URL}/auth/v1/.well-known/jwks.json`. We fetch
# this on first request and cache the keys for `JWKS_CACHE_TTL_SECONDS`
# (default 3600), refreshing on `kid` cache-miss.
SUPABASE_JWKS_URL=

# Expected `aud` claim. Defaults to "authenticated" — the value Supabase
# stamps onto end-user tokens. Override only if a custom audience is in use.
SUPABASE_JWT_AUD=authenticated

# Expected `iss` claim. Typically `${SUPABASE_URL}/auth/v1`. Required when
# more than one Supabase project might issue tokens to this service.
SUPABASE_JWT_ISS=

# JWKS cache TTL in seconds. The cache also refreshes on a kid cache-miss
# (rate-limited to once per 30s per kid) so key rotation is handled without
# a service restart.
JWKS_CACHE_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Accredited investor verification (prompt 26)
# ---------------------------------------------------------------------------
#
# These vars configure the LP-side accreditation-verification adapters. They
# are NOT required for default development or CI: the test suite exercises
# the backends with locally-injected secrets, and the manual backend is the
# only provider that runs without any env config (its dry-run upload secret
# falls back to a built-in default). When unset, attempting to initiate a
# Persona or Onfido verification at runtime returns 503 PROVIDER_UNAVAILABLE.
#
# Webhook signature verification is NEVER bypassed, even in dry-run — see
# `docs/specs/accredited_investor_verification.md`.

# Persona — server-side API key (never exposed to clients).
PERSONA_API_KEY=
# Persona — HMAC secret used to verify webhook deliveries.
PERSONA_WEBHOOK_SECRET=
# Persona — pinned inquiry template id.
PERSONA_TEMPLATE_ID=

# Onfido — server-side API token.
ONFIDO_API_TOKEN=
# Onfido — webhook token used to verify HMAC-signed deliveries.
ONFIDO_WEBHOOK_TOKEN=

# Manual backend — secret used to mint short-lived upload tokens for the
# operator UI's evidence-upload form. Optional; defaults to a built-in
# dry-run secret when unset (sufficient for local development).
ACCREDITATION_MANUAL_UPLOAD_SECRET=

# ---------------------------------------------------------------------------
# Object storage (transcripts, argument graphs, decision artifact bodies)
# ---------------------------------------------------------------------------
#
# All large blobs go through the storage adapter rather than the database.
# CI defaults to the local filesystem backend; staging / prod set this to
# ``s3`` or ``supabase``. See ``docs/specs/object_storage.md`` for the URI
# grammar (``coh://<backend>/<bucket>/<key>``), tombstone lifecycle, and
# signed-URL flow.

# One of: local | s3 | supabase. Default: local.
STORAGE_BACKEND=local

# Local backend — root directory and bucket subdir.
LOCAL_STORAGE_ROOT=./var/object_storage
LOCAL_STORAGE_BUCKET=default

# S3 backend — bucket name; AWS credentials/region come from the standard
# boto3 chain (env vars, instance profile, etc.).
S3_BUCKET=

# Supabase Storage backend — bucket name. ``SUPABASE_URL`` and
# ``SUPABASE_SERVICE_ROLE_KEY`` (declared above) are also required.
SUPABASE_STORAGE_BUCKET=

# ---------------------------------------------------------------------------
# Twilio Voice intake (prompt 38)
# ---------------------------------------------------------------------------
#
# Phone-based founder interview ingress. The Twilio adapter consumes these
# at runtime; tests inject a fake client and never call the real API.
# Webhook signature verification is mandatory in staging/prod and may only
# be opted out of in dev (see ``docs/specs/voice_intake.md``).

# Twilio Account SID — public discriminator for the account.
TWILIO_ACCOUNT_SID=
# Twilio Auth Token — server-side only, used for signature verification of
# inbound webhooks AND HTTP basic auth on outbound recording fetches.
TWILIO_AUTH_TOKEN=
# Twilio caller-id phone number in E.164 form (e.g. ``+15555550100``).
TWILIO_FROM_NUMBER=
# Whether to enforce X-Twilio-Signature on inbound webhooks. Defaults to
# ``true``. May only be set to ``false`` in ``dev`` (the gate in
# ``twilio_webhooks._signature_validation_required`` ignores the override
# in ``staging``/``prod``).
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true

# ---------------------------------------------------------------------------
# Speech-to-text (prompt 40)
# ---------------------------------------------------------------------------
#
# Three pluggable backends sit behind the SpeechToText interface:
# whisper (local), deepgram, assemblyai. The router calls the primary
# first and falls back to the secondary on transient error or when the
# primary returns a transcript whose average word confidence is below
# STT_MIN_AVG_CONFIDENCE. Both unset → no STT runs (legacy behavior).

# Primary STT provider: whisper | deepgram | assemblyai. Defaults to
# "whisper" when constructed via STTRouter.from_env(), but the
# voice_intake helper treats UNSET as "skip STT" so existing dev
# environments without ML wheels do not regress.
STT_PROVIDER_PRIMARY=

# Optional secondary provider. Leave blank to disable fallback.
STT_PROVIDER_FALLBACK=

# Average word-confidence threshold for the LOW_STT_CONFIDENCE flag.
# Below this the router will try the fallback (if any) and ultimately
# stamp the flag onto the returned STTResult.quality_flags.
STT_MIN_AVG_CONFIDENCE=0.6

# Whisper checkpoint name passed to faster_whisper / whisper.load_model.
# Common values: tiny, base, small, medium, large-v3.
WHISPER_MODEL=base

# Managed provider API keys — server-side only, NEVER expose to clients.
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# ---------------------------------------------------------------------------
# Capital deployment (prompt 51)
# ---------------------------------------------------------------------------
#
# These vars configure the capital-deployment surface that prepares
# investment transfers via Stripe Connect or a bank API (Mercury default).
# The system NEVER moves money on its own — every transfer requires an
# authenticated treasurer approval and a treasurer-initiated execute call.
# See ``docs/specs/capital_deployment.md`` for the non-autonomy invariant.

# Stripe — server-side secret key; required only for the StripeConnectBackend.
STRIPE_SECRET_KEY=
# Stripe Connect platform/connected-account id used as the transfer target.
STRIPE_CONNECT_ACCOUNT_ID=
# HMAC secret used to verify ``Stripe-Signature`` on the funding webhook.
STRIPE_WEBHOOK_SECRET=

# Mercury (bank-transfer backend) — server-side API token. Optional override
# for the API base URL when pointed at a sandbox.
MERCURY_API_TOKEN=
MERCURY_API_BASE=https://api.mercury.com/api/v1

# Threshold (in USD) at which an instruction requires two distinct
# treasurer approvals before execute. Defaults to 250000.
CAPITAL_DUAL_APPROVAL_THRESHOLD_USD=250000

# ---------------------------------------------------------------------------
# E-signature providers (prompt 52)
# ---------------------------------------------------------------------------
#
# Pluggable backends for SAFE / term-sheet signature requests:
# DocuSign or Dropbox Sign (formerly HelloSign). Webhook signature
# verification is mandatory and has no env-gated bypass; the routes
# return HTTP 401 on failure and never mutate state. See
# ``docs/specs/esignature.md`` for the lifecycle, signature-scheme
# details, and storage discipline (the unsigned document body is
# rendered in memory and never persisted).
#
# OPERATOR OBLIGATION: the SAFE template that ships under
# ``server/fund/data/legal_templates/`` is a PLACEHOLDER. Production
# templates MUST be reviewed by securities counsel before any
# signature request is sent. This software does not produce legal
# advice.

# DocuSign — server-side integration (JWT grant). The integration
# key + user id + RSA private key combine to issue a JWT against
# DocuSign's auth service.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_RSA_PRIVATE_KEY=

# Comma-separated list of active DocuSign Connect HMAC v2 secrets.
# Up to 10 are supported per account; rotation is done by appending
# the new secret, redeploying, then removing the old once Connect is
# updated. At least one is required to verify webhook deliveries.
DOCUSIGN_CONNECT_HMAC_SECRETS=

# Dropbox Sign — server-side API key. The same key is used both for
# outbound API calls (HTTP basic auth) and for verifying webhook
# event hashes per Dropbox Sign's documented HMAC scheme.
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_API_BASE=https://api.hellosign.com/v3

# ---------------------------------------------------------------------------
# Calendar / scheduling (prompt 54)
# ---------------------------------------------------------------------------
#
# Pluggable backends behind the partner-meeting Scheduler:
# Cal.com (primary, hosted scheduling API) or Google Calendar
# (fallback for personal calendars). Both SDK chains are imported
# lazily so neither is a hard dependency. See
# ``docs/specs/scheduling.md`` for the propose/book lifecycle, the
# 72-hour token TTL (NO env-gated bypass), and the three-slots-max
# bandwidth cap.

# Active backend: calcom | google_calendar. Defaults to ``calcom``.
SCHEDULER_PROVIDER=calcom

# Fallback partner email used by the ``scheduling_requested`` event
# emitted on every enforce-mode ``pass`` decision until the
# dedicated partner-routing surface lands.
SCHEDULER_DEFAULT_PARTNER_EMAIL=

# Cal.com — server-side API key + the booking event-type id that
# the founder click-through targets.
CALCOM_API_KEY=
CALCOM_API_BASE=https://api.cal.com/v1
CALCOM_EVENT_TYPE_ID=

# Google Calendar — OAuth client credentials + a long-lived refresh
# token issued against the service / booking-bot account whose
# calendar should host the events. ``GOOGLE_CALENDAR_CALENDAR_ID``
# defaults to ``primary``.
GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_CALENDAR_ID=primary

# ---------------------------------------------------------------------------
# CRM bidirectional sync (prompt 55)
# ---------------------------------------------------------------------------
#
# Pluggable CRM backends behind the ``CRMSyncService``: Affinity is
# the primary integration; HubSpot is the alternate. Outbound upserts
# fire on Application status / Decision verdict changes via the
# ``crm_upsert_requested`` outbox event. Inbound webhooks at
# ``/webhooks/crm/{affinity,hubspot}`` apply partner-side edits with
# a last-writer-wins policy for tags/notes; the partner-side deal
# stage label NEVER mutates ``Decision.decision``. A daily
# reconciliation cron repairs missed deliveries. See
# ``docs/specs/crm_sync.md``.
#
# Webhook signature verification is mandatory (no env-gated bypass).

# Affinity — server-side REST API key.
AFFINITY_API_KEY=
# Affinity — HMAC secret used to verify inbound webhook deliveries.
AFFINITY_WEBHOOK_SECRET=
AFFINITY_API_BASE=https://api.affinity.co

# HubSpot — Private App access token (used for outbound API calls).
HUBSPOT_PRIVATE_APP_TOKEN=
# HubSpot — app secret used to verify v3 webhook signatures.
HUBSPOT_WEBHOOK_SECRET=
HUBSPOT_API_BASE=https://api.hubapi.com

# ---------------------------------------------------------------------------
# Cap-table provider (prompt 68)
# ---------------------------------------------------------------------------
#
# Pluggable cap-table backends behind ``CapTableService``. Carta is the
# primary integration; Pulley is the alternate. The service is
# RECORD-KEEPING ONLY: it records issuances the operator has caused
# via the upstream investment workflow (signed SAFE + sent investment
# instruction). It does NOT unilaterally issue securities.
#
# Sync trigger: ``ApplicationService.maybe_sync_cap_table`` runs only
# when both ``SignatureRequest.status == "signed"`` AND
# ``InvestmentInstruction.status == "sent"`` for the application.
# Idempotent on retry. See ``docs/specs/cap_table.md``.

# Provider selector: ``carta`` (default) | ``pulley``.
CAP_TABLE_PROVIDER=carta

# Carta — server-side REST API token.
CARTA_API_TOKEN=
CARTA_API_BASE=https://api.carta.com/v1

# Pulley — server-side REST API token.
PULLEY_API_TOKEN=
PULLEY_API_BASE=https://api.pulley.com/v1
