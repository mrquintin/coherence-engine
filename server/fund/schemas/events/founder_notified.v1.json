{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coherence-engine/events/founder_notified/v1",
  "title": "FounderNotifiedV1",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "schema_version",
    "occurred_at",
    "application_id",
    "channel",
    "template_id",
    "notification_status"
  ],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_name": {"type": "string", "const": "founder_notified"},
    "schema_version": {"type": "integer", "const": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "application_id": {"type": "string", "minLength": 1},
    "channel": {"type": "string", "enum": ["email", "sms", "dry_run"]},
    "template_id": {"type": "string", "minLength": 1},
    "notification_status": {
      "type": "string",
      "enum": ["queued", "sent", "failed", "suppressed"]
    },
    "founder_id": {"type": "string", "minLength": 1},
    "recipient": {"type": "string", "minLength": 1},
    "decision_id": {"type": "string", "minLength": 1},
    "failure_reason": {"type": "string"}
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "44444444-4444-4444-8444-444444444444",
      "event_name": "founder_notified",
      "schema_version": 1,
      "occurred_at": "2026-04-16T12:15:00Z",
      "application_id": "app_abc123",
      "channel": "email",
      "template_id": "decision_notification_v1",
      "notification_status": "sent"
    }
  ]
}
