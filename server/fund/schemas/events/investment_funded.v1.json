{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coherence-engine/events/investment_funded/v1",
  "title": "InvestmentFundedV1",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "schema_version",
    "occurred_at",
    "instruction_id",
    "application_id",
    "founder_id",
    "amount_usd",
    "currency",
    "preparation_method",
    "treasurer_id"
  ],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_name": {"type": "string", "const": "investment_funded"},
    "schema_version": {"type": "integer", "const": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "instruction_id": {"type": "string", "minLength": 1},
    "application_id": {"type": "string", "minLength": 1},
    "founder_id": {"type": "string", "minLength": 1},
    "amount_usd": {"type": "integer", "minimum": 1},
    "currency": {"type": "string", "minLength": 3, "maxLength": 8},
    "preparation_method": {"type": "string", "enum": ["stripe", "bank_transfer"]},
    "provider_intent_ref": {"type": "string"},
    "treasurer_id": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "22222222-2222-4222-8222-222222222222",
      "event_name": "investment_funded",
      "schema_version": 1,
      "occurred_at": "2026-04-25T12:30:00Z",
      "instruction_id": "ins_abc123",
      "application_id": "app_abc123",
      "founder_id": "fnd_abc123",
      "amount_usd": 100000,
      "currency": "USD",
      "preparation_method": "bank_transfer",
      "provider_intent_ref": "pmt_zzz",
      "treasurer_id": "treasurer:bob"
    }
  ]
}
