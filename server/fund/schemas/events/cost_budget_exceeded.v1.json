{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coherence-engine/events/cost_budget_exceeded/v1",
  "title": "CostBudgetExceededV1",
  "type": "object",
  "required": [
    "event_id",
    "event_name",
    "schema_version",
    "occurred_at",
    "scope",
    "scope_key",
    "budget_usd",
    "total_usd"
  ],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_name": {"type": "string", "const": "cost_budget_exceeded"},
    "schema_version": {"type": "integer", "const": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "scope": {
      "type": "string",
      "enum": ["application", "daily"]
    },
    "scope_key": {"type": "string", "minLength": 1},
    "budget_usd": {"type": "number", "minimum": 0},
    "total_usd": {"type": "number", "minimum": 0},
    "cooldown_hours": {"type": "number", "minimum": 0}
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "66666666-6666-4666-8666-666666666666",
      "event_name": "cost_budget_exceeded",
      "schema_version": 1,
      "occurred_at": "2026-04-25T17:30:00Z",
      "scope": "application",
      "scope_key": "app_abc123",
      "budget_usd": 5.0,
      "total_usd": 5.42,
      "cooldown_hours": 24
    }
  ]
}
